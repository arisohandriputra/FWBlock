IDD_ABOUTBOX DIALOGEX 0, 0, 240, 135
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About FWBlock"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    ICON            IDI_FIREWALLBLOCKER,IDC_MYICON,10,10,20,20
    LTEXT           "FWBlock - Firewall & Process Blocker",IDC_ABOUT_NAME,42,10,185,12,SS_NOPREFIX
    LTEXT           "Version 2.1",IDC_ABOUT_VER,42,24,185,10
    LTEXT           "Author  :  Ari Sohandri Putra",IDC_ABOUT_DESC,10,40,215,10
    LTEXT           "Blocks EXE files via Windows Firewall (INetFwPolicy2) and process execution (IFEO registry method). Requires Administrator privileges.",IDC_STATIC,10,56,215,36
